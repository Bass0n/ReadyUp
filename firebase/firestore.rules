rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function validStatus(status) {
      return status in ['Playing', 'Finished', 'Completed', 'On Hold', 'Dropped', 'Wishlist'];
    }

    function validRating(rating) {
      return rating == null || (rating is int && rating >= 1 && rating <= 10);
    }

    match /game_cache/{rawgId} {
      allow read: if true;
      allow write: if signedIn();
    }

    match /users/{userId} {
      allow read, create, update, delete: if signedIn() && request.auth.uid == userId;

      match /games/{rawgId} {
        allow read, delete: if signedIn() && request.auth.uid == userId;
        allow create, update: if signedIn()
          && request.auth.uid == userId
          && validStatus(request.resource.data.status)
          && validRating(request.resource.data.rating);
      }
    }
  }
}
